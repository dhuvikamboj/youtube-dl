# Copy this file to .env and edit the values for your server.

# Where downloaded video/audio files are stored.
DOWNLOAD_DIR=./downloads

# Where SQLite job history is stored.
DATABASE_PATH=./downloads.sqlite3

# Keep this at 1 for small servers. Increase if your CPU/network can handle it.
MAX_CONCURRENT_DOWNLOADS=1

# Web login.
APP_USERNAME=admin
APP_PASSWORD=change-this-password

# Use a long random value in production.
SECRET_KEY=change-this-secret
